{
  "multipart": [
    {
      "apply": {
        "model": "nextondynamics:block/energy_cable_core"
      }
    },
    {
      "when": { "north": "true" },
      "apply": {
        "model": "nextondynamics:block/energy_cable_side"
      }
    },
    {
      "when": { "east": "true" },
      "apply": {
        "model": "nextondynamics:block/energy_cable_side",
        "y": 90
      }
    },
    {
      "when": { "south": "true" },
      "apply": {
        "model": "nextondynamics:block/energy_cable_side",
        "y": 180
      }
    },
    {
      "when": { "west": "true" },
      "apply": {
        "model": "nextondynamics:block/energy_cable_side",
        "y": 270
      }
    },
    {
      "when": { "up": "true" },
      "apply": {
        "model": "nextondynamics:block/energy_cable_side",
        "x": 270
      }
    },
    {
      "when": { "down": "true" },
      "apply": {
        "model": "nextondynamics:block/energy_cable_side",
        "x": 90
      }
    }
  ]
}
