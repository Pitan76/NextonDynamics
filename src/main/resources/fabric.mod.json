  "authors": [
    "Pitan"
  ],
  "contact": {
    "sources": "https://github.com/Pitan76/NextonDynamics",
    "issues": "https://github.com/Pitan76/NextonDynamics/issues",
    "homepage": "https://curseforge/minecraft/mc-mods/nexton-dynamics"
  },
  "license": "MIT",
  "icon": "assets/nextondynamics/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.pitan76.nexton.dynamics.NextonDynamics"
    ],
    "client": [
      "net.pitan76.nexton.dynamics.client.NextonDynamicsClient"
    ]
  },
  "depends": {
    "fabricloader": "*",
    "minecraft": "*",
    "mcpitanlib": ">3.6.7",
    "nextoncore": "*"
  },
  "recommends": {
